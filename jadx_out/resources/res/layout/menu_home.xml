<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/transparent"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ImageView
        android:layout_gravity="end"
        android:layout_width="14dp"
        android:layout_height="7dp"
        android:src="@drawable/triangle"
        android:layout_marginEnd="20dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/menu_white_bg"
        android:layout_width="140dp"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="start|center_vertical"
            android:orientation="horizontal"
            android:id="@+id/menu_account"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingStart="@dimen/dp10">
            <ImageView
                android:id="@+id/menu_account_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/menu_user"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gray3"
                android:ellipsize="middle"
                android:id="@+id/menu_account_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/activate_vip"
                android:maxLines="1"
                android:singleLine="true"
                android:paddingEnd="@dimen/dp10"
                android:layout_marginStart="7dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/menu_account_icon"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:background="@color/gray4"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="start|center_vertical"
            android:orientation="horizontal"
            android:id="@+id/menu_clear"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingStart="@dimen/dp10">
            <ImageView
                android:id="@+id/imageView8"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/menu_clear"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gray3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_clear_cache"
                android:layout_marginStart="7dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imageView8"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:background="@color/gray4"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="start|center_vertical"
            android:orientation="horizontal"
            android:id="@+id/menu_set_permiss"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingStart="@dimen/dp10">
            <ImageView
                android:id="@+id/imageView7"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/menu_permission"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gray3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_permission_settings"
                android:layout_marginStart="7dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imageView7"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:background="@color/gray4"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="start|center_vertical"
            android:orientation="horizontal"
            android:id="@+id/menu_share"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingStart="@dimen/dp10">
            <ImageView
                android:id="@+id/imageView6"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/menu_share"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gray3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_share"
                android:layout_marginStart="7dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imageView6"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:background="@color/gray4"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="start|center_vertical"
            android:orientation="horizontal"
            android:id="@+id/menu_give"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingStart="@dimen/dp10">
            <ImageView
                android:id="@+id/imageView5"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/menu_give_vip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gray3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/give_vip"
                android:layout_marginStart="7dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imageView5"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:background="@color/gray4"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="start|center_vertical"
            android:orientation="horizontal"
            android:id="@+id/menu_help"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingStart="@dimen/dp10">
            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/menu_help"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gray3"
                android:id="@+id/tv_help"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_help"
                android:layout_marginStart="7dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imageView4"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/red_point_help"
                android:background="@drawable/red_point"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                app:layout_constraintBottom_toBottomOf="@+id/tv_help"
                app:layout_constraintStart_toEndOf="@+id/tv_help"
                app:layout_constraintTop_toTopOf="@+id/tv_help"/>
            <View
                android:background="@color/gray4"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="start|center_vertical"
            android:orientation="horizontal"
            android:id="@+id/menu_data_management"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingStart="@dimen/dp10">
            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/ic_data_manager"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gray3"
                android:id="@+id/tv_data_management"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数据管理"
                android:layout_marginStart="7dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imageView3"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:background="@color/gray4"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/menu_process_limits"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingStart="@dimen/dp10">
            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/menu_about_us"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gray3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="进程限制"
                android:layout_marginStart="7dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imageView2"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:background="@color/gray4"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            android:gravity="start|center_vertical"
            android:orientation="horizontal"
            android:id="@+id/menu_aboutus"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingStart="@dimen/dp10"
            android:paddingEnd="20dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/menu_about_us"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/gray3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_abouts"
                android:layout_marginStart="7dp"/>
            <ImageView
                android:id="@+id/red_point"
                android:background="@drawable/red_point"
                android:visibility="invisible"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginStart="5dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
