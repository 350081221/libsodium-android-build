<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@drawable/menu_white_bg"
    android:layout_width="300dp"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/holo_red_dark"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tip_delete"
        app:layout_constraintBottom_toBottomOf="@+id/iv_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iv_close"/>
    <ImageView
        android:id="@+id/iv_close"
        android:padding="15dp"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@mipmap/ic_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="15sp"
        android:textColor="@color/gray3"
        android:gravity="center_vertical"
        android:id="@+id/delete_msg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="25dp"
        android:layout_marginRight="20dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
    <com.google.android.material.button.MaterialButton
        android:textSize="15sp"
        android:textColor="@color/cancel_tx_color"
        android:gravity="center"
        android:id="@+id/btn_cancel"
        android:layout_width="120dp"
        android:layout_height="40dp"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="15dp"
        android:text="@string/cancel_msg"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:layout_marginStart="20dp"
        android:backgroundTint="@color/cancel_color"
        app:cornerRadius="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/delete_msg"/>
    <com.google.android.material.button.MaterialButton
        android:textSize="15sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/btn_confirm"
        android:layout_width="120dp"
        android:layout_height="40dp"
        android:text="@string/confirm"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:layout_marginEnd="15dp"
        android:backgroundTint="@color/confirm_color"
        app:cornerRadius="5dp"
        app:layout_constraintBottom_toBottomOf="@+id/btn_cancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btn_cancel"/>
</androidx.constraintlayout.widget.ConstraintLayout>
