<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="180dp">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:background="@drawable/item_launcher_bg"
        android:layout_width="match_parent"
        android:layout_height="180dp">
        <ImageView
            android:id="@+id/item_app_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="15dp"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/gray3"
            android:ellipsize="middle"
            android:gravity="center"
            android:id="@+id/item_app_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:singleLine="true"/>
        <TextView
            android:textSize="10sp"
            android:textColor="@color/gray7"
            android:ellipsize="end"
            android:layout_gravity="center_horizontal"
            android:id="@+id/item_note_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dp10"
            android:layout_marginTop="2dp"
            android:layout_marginRight="@dimen/dp10"
            android:maxLines="2"
            android:layout_marginHorizontal="@dimen/dp10"/>
    </LinearLayout>
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_preview"
        android:background="@color/black"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/roundedImageStyle"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/lay_mask"
        android:background="@drawable/item_launcher_mask_layer_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="10sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_open"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="快速进入"/>
        <TextView
            android:textSize="10sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_manager"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="应用管理"/>
    </LinearLayout>
    <ImageView
        android:layout_gravity="end|top"
        android:id="@+id/item_checkbox"
        android:visibility="invisible"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/selector_check"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:layout_gravity="end|top"
        android:id="@+id/item_lock"
        android:paddingTop="5dp"
        android:visibility="invisible"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/lock"
        android:paddingEnd="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</FrameLayout>
