<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="horizontal"
    android:id="@+id/rit_detail_preview_input"
    android:background="@drawable/shape_dialog_header_bg"
    android:paddingLeft="16dp"
    android:paddingTop="12dp"
    android:paddingRight="16dp"
    android:paddingBottom="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="15sp"
        android:textColor="#161823"
        android:gravity="center"
        android:id="@+id/preview_dialog_cancel"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:text="取消"/>
    <TextView
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#161823"
        android:gravity="center"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="请选择"
        android:layout_weight="1"/>
    <TextView
        android:textSize="15sp"
        android:textColor="#f93f3f"
        android:gravity="center"
        android:id="@+id/preview_dialog_ensure"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:text="确认"/>
</LinearLayout>
