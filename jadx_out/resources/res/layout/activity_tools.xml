<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <View
        android:background="#1e161823"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="52dp">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/base_setting"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="15sp"
                android:id="@+id/base_setting_text"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_marginTop="19dp"
                android:text="基础信息"
                android:layout_weight="1"/>
            <View
                android:id="@+id/base_setting_indication"
                android:background="#000000"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/global_setting"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="15sp"
                android:id="@+id/global_setting_text"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_marginTop="19dp"
                android:text="全局配置"
                android:layout_weight="1"/>
            <View
                android:id="@+id/global_setting_indication"
                android:background="#000000"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/rit_setting"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="15sp"
                android:id="@+id/rit_setting_text"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_marginTop="19dp"
                android:text="代码位检测"
                android:layout_weight="1"/>
            <View
                android:id="@+id/rit_setting_indication"
                android:background="#000000"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="#1e161823"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginLeft="19dp"
        android:layout_marginRight="19dp"/>
    <androidx.viewpager.widget.ViewPager
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
